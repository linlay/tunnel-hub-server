{
	email admin@tunnel-hub.zenmind.cc
}

tunnel-hub.zenmind.cc {
	handle /api/admin* {
		reverse_proxy relay:8080
	}

	handle /api/desktop* {
		reverse_proxy relay:8080
	}

	handle /api/upload {
		respond 404
	}

	handle /api/resource {
		respond 404
	}

	handle /api/download {
		respond 404
	}

	handle /api/download/* {
		respond 404
	}

	handle /api/pull/* {
		reverse_proxy relay:8080
	}

	handle /api/push/* {
		reverse_proxy relay:8080
	}

	handle /tunnel {
		reverse_proxy relay:8080
	}

	handle {
		reverse_proxy website:80
	}
}

# Public wildcard routes require DNS for *.m.zenmind.cc and *.wa.zenmind.cc.
# Public ACME wildcard certificates usually require a DNS challenge provider.
*.m.zenmind.cc {
	@mobileWebApp host_regexp mobileWebApp ^[^.]+-[0-9]+\.m\.zenmind\.cc$
	handle @mobileWebApp {
		reverse_proxy relay:8080
	}

	handle /api/upload {
		reverse_proxy relay:8080
	}

	handle /api/resource {
		reverse_proxy relay:8080
	}

	handle /api/pull/* {
		reverse_proxy relay:8080
	}

	handle /api/push/* {
		reverse_proxy relay:8080
	}

	handle /api/download {
		respond 404
	}

	handle /api/download/* {
		respond 404
	}

	@desktopWs {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	handle @desktopWs {
		reverse_proxy relay:8080
	}
	handle {
		reverse_proxy public:80
	}
}

*.wa.zenmind.cc {
	reverse_proxy relay:8080
}
