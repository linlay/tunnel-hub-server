	email admin@tunnel-hub.zenmind.cc
}

tunnel-hub.zenmind.cc {
	handle /api/admin* {
		reverse_proxy relay:8080
	}

	handle /api/desktop* {
		reverse_proxy relay:8080
	}

	handle /tunnel {
		reverse_proxy relay:8080
	}

	handle {
		reverse_proxy website:80
	}
}

# Public wildcard routes require DNS for *.m.zenmind.cc.
# Public ACME wildcard certificates usually require a DNS challenge provider.
*.m.zenmind.cc {
	reverse_proxy relay:8080
}
