# Relay listen address for local Go runs.
RELAY_ADDR=:8080

# Local Go runs use a project-local SQLite database.
# docker-compose.yml overrides this to /data/zenmind-tunnel.db inside the container.
RELAY_DB_PATH=zenmind-tunnel.db

# Legacy static website hosting. Leave empty for the split website/server deployment.
ADMIN_HOST=
WEBSITE_DIST=

# Public base domain used when creating managed service hosts.
PUBLIC_BASE_DOMAIN=localhost

# Replace in production with a long, stable random value.
COOKIE_SECRET=replace-with-a-long-random-secret

# First admin account created during bootstrap.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin

# Maximum buffered HTTP request body size, in bytes.
MAX_REQUEST_BODY_BYTES=67108864
