# Relay listen address for local Go runs.
RELAY_ADDR=:8080

# Local Go runs use a project-local SQLite database.
# docker-compose.yml overrides this to /data/tunnel.db inside the container.
RELAY_DB_PATH=tunnel.db

# Legacy static website hosting. Leave empty for the split website/server deployment.
ADMIN_HOST=
WEBSITE_DIST=

# Public base domain used when creating managed service hosts.
PUBLIC_BASE_DOMAIN=localhost

# Official-site SSO JWT verifier. Required for admin and Desktop registration APIs.
SSO_JWT_ISSUER=https://zenmind.cc
SSO_JWT_PUBLIC_KEY_FILE=configs/zenmind-sso-jwt-public.pem
SSO_JWT_PUBLIC_KEY_PEM=
SSO_JWT_AUDIENCE=zenmind-tunnel-hub-server

# Maximum buffered HTTP request body size, in bytes.
MAX_REQUEST_BODY_BYTES=67108864
