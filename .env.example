# Relay listen address for local Go runs.
RELAY_ADDR=:8080

# Local Go runs use a project-local SQLite database.
# docker-compose.yml overrides this to /data/tunnel.db inside the container.
RELAY_DB_PATH=tunnel.db

# Legacy static website hosting. Leave empty for the split website/server deployment.
ADMIN_HOST=
WEBSITE_DIST=

# Public base domain used when creating managed service hosts.
PUBLIC_BASE_DOMAIN=localhost

# Local admin login for the management website. Only set ADMIN_PASSWORD when you
# want to bootstrap the first local admin user.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_SESSION_TTL=24h
COOKIE_SECURE=false

# Official-site SSO JWT verifier. Required for official JWT admin access and Desktop registration APIs.
SSO_JWT_ISSUER=https://zenmind.cc
SSO_JWT_PUBLIC_KEY_FILE=configs/jwt-public.pem
SSO_JWT_PUBLIC_KEY_PEM=
SSO_JWT_AUDIENCE=zenmind-tunnel-hub-server

# Maximum buffered HTTP request body size, in bytes.
MAX_REQUEST_BODY_BYTES=67108864

# Desktop public mini site HTTP port. Reverse proxy should send ordinary
# *.m.zenmind.cc HTTP traffic here while WebSocket upgrades stay on the relay.
TUNNEL_HUB_PUBLIC_PORT=11965

# Trusted reverse proxy CIDRs for reading X-Real-IP / X-Forwarded-For.
# Production Docker + nginx deployments usually use:
# TRUSTED_PROXY_CIDRS=172.23.0.1/32,127.0.0.1/32,::1/128
TRUSTED_PROXY_CIDRS=
